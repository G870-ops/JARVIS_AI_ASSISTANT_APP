<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/jarvis_bg"
    android:gravity="center">

    <!-- Circular Glowing JARVIS Core -->
    <ImageView
        android:id="@+id/jarvisCircle"
        android:layout_width="250dp"
        android:layout_height="250dp"
        android:layout_centerInParent="true"
        android:src="@drawable/img"
        android:contentDescription="Jarvis Animated Core"
        android:scaleType="centerInside"
        android:animation="@anim/core_pulse"/>

    <!-- Speak Button -->
    <Button
        android:id="@+id/btnSpeak"
        android:layout_width="200dp"
        android:layout_height="55dp"
        android:layout_below="@id/jarvisCircle"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="40dp"
        android:text="ACTIVATE JARVIS"
        android:textColor="#00E5FF"
        android:textSize="16sp"
        android:backgroundTint="#001F3F"
        android:elevation="12dp"
        android:stateListAnimator="@animator/button_elevation"/>

    <!-- Text Command Input -->
    <EditText
        android:id="@+id/etCommand"
        android:layout_width="280dp"
        android:layout_height="50dp"
        android:layout_below="@id/btnSpeak"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="30dp"
        android:hint="Type your command..."
        android:textColor="#F44336"
        android:textColorHint="#80E5FF"
        android:backgroundTint="#00E5FF"
        android:padding="10dp"/>

    <!-- Send Command Button -->
    <Button
        android:id="@+id/btnSend"
        android:layout_width="150dp"
        android:layout_height="50dp"
        android:layout_below="@id/etCommand"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="15dp"
        android:backgroundTint="#001F3F"
        android:text="SEND COMMAND"
        android:textColor="#00E5FF" />
</RelativeLayout>


